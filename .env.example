APP_ENV=local
HTTP_ADDR=:8080
HTTP_READ_TIMEOUT=30s
HTTP_WRITE_TIMEOUT=120s
HTTP_SHUTDOWN_TIMEOUT=15s

DATABASE_URL=postgres://marketpclce:marketpclce@localhost:5432/marketpclce?sslmode=disable
DATABASE_MAX_CONNS=10

OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX_SPECIALISTS=specialists

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# S3 — Yandex Object Storage (для всех окружений). Без ключей API стартует,
# /me/portfolio/upload-url возвращает 503 storage_disabled — для локалки
# можно оставить пустыми, если не работаешь с аплоадом видео.
# Static access key из service account: console.cloud.yandex.ru.
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_USE_SSL=true
# Пустое = path-style ${endpoint}/${bucket}. Или CNAME: https://media.example.com
S3_PUBLIC_URL=

LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6
LLM_BASE_URL=https://api.anthropic.com
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=60s
LLM_EFFORT=medium

JWT_SECRET=please-change-me-in-prod-32-bytes-min
JWT_ACCESS_TTL=30m
JWT_REFRESH_TTL=168h

SUMMARIZE_CACHE_TTL=10m
RATE_SUMMARIZE_PER_MIN=5
RATE_SUMMARIZE_PER_HOUR=30
RATE_READ_PER_MIN=60
RATE_READ_PER_HOUR=600
RATE_LEADS_PER_MIN=5
RATE_LEADS_PER_HOUR=20
RATE_AUTH_PER_MIN=10
RATE_AUTH_PER_HOUR=60

# ── Email verification (Unisender Go) ───────────────────────────────
# Для локального запуска по дефолту verification выключен: юзеры сразу
# email_verified=true при регистрации, soft-gate на /me/profile/publish
# и POST /leads пропускает. В проде .env.prod должен ставить =false.
EMAIL_VERIFICATION_DISABLED=true

# Если хочется потестить флоу подтверждения локально:
#   1. Выключи EMAIL_VERIFICATION_DISABLED=false выше.
#   2. Оставь UNISENDER_API_KEY пустым.
#   3. Воркер залогирует verify-URL в stdout — копируй из логов
#      и открывай руками в браузере.
# Чтобы реально слать письма (стейджинг/прод) — заполни UNISENDER_API_KEY.
UNISENDER_API_KEY=
UNISENDER_API_BASE_URL=https://goapi.unisender.ru/ru/transactional/api/v1
UNISENDER_FROM_EMAIL=noreply@example.com
UNISENDER_FROM_NAME=marketpclce
APP_BASE_URL=http://localhost:5173
EMAIL_VERIFY_TOKEN_TTL=24h
RATE_EMAIL_RESEND_PER=60s

# Outbox-воркер: backoff/DLQ/TTL. После OUTBOX_MAX_ATTEMPTS неуспехов
# событие уезжает в DLQ (dead_at NOT NULL) и больше не ретраится.
OUTBOX_MAX_ATTEMPTS=10
OUTBOX_BACKOFF_CAP=10m
OUTBOX_RETENTION=168h
OUTBOX_CLEANUP_INTERVAL=1h
WORKER_METRICS_ADDR=:9090

LOG_LEVEL=debug

# Разрешённые origin'ы фронта (через запятую). Пусто = CORS-заголовки
# не выставляются (фронт обслуживается с того же домена через прокси).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Directus (локально только) ─────────────────────────────────────
# Значения для compose уже захардкожены в docker-compose.yml (KEY/SECRET/
# bootstrap-админ). Сюда кладём только service-token, который наш
# Go API проверяет на /admin/*. Сгенерировать:
#   go run ./cmd/service-token
# и вставить значение. Без него Directus Flows не смогут ходить в API
# (но саму админку открыть можно).
DIRECTUS_SERVICE_TOKEN=

# ── n8n (локально опционально) ─────────────────────────────────────
# Endpoint webhook'а в n8n, куда worker шлёт project.* и
# client_invite.* outbox-события. Пусто = диспатчер выключен, события
# уходят в DLQ через MaxAttempts ретраев (для локалки норм).
# Локально n8n не поднимаем — это прод-инструмент. Для тестирования
# можно запустить webhook.site и вставить тестовый URL сюда.
N8N_WEBHOOK_BASE_URL=
N8N_HTTP_TIMEOUT=10s
