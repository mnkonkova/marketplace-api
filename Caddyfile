# Caddy: TLS-терминатор + reverse-proxy. DOMAIN берётся из env compose'а.
# При первом запуске Caddy сам выпишет Let's Encrypt-сертификат через
# HTTP-01 challenge — для этого DNS-имя должно резолвиться на IP сервера
# и порт 80 должен быть открыт. HTTP→HTTPS Caddy делает автоматически.

{$DOMAIN} {
	encode zstd gzip

	# API + статика веба обслуживаются одним Go-бинарём (см. mountStatic
	# в internal/httpapi/router.go); caddy просто проксирует всё на :8080.
	reverse_proxy api:8080 {
		# Прокидываем реальный клиент IP, чтобы rate-limiter видел его, а
		# не адрес caddy-сервиса.
		header_up X-Forwarded-For {remote_host}
		header_up X-Real-IP {remote_host}
	}
}
