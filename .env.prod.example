# .env.prod — копия для прод-VDS. cp .env.prod.example .env.prod и заполни.
# Все хосты сервисов = имена сервисов в docker-compose.prod.yml (postgres /
# opensearch / redis), наружу торчит только caddy.

APP_ENV=prod
HTTP_ADDR=:8080
HTTP_READ_TIMEOUT=30s
HTTP_WRITE_TIMEOUT=120s
HTTP_SHUTDOWN_TIMEOUT=15s

# ── Домен для Caddy (Let's Encrypt). Должен резолвиться на IP сервера.
# Например: marketpclce-beta.timeweb.cloud
DOMAIN=

# ── PostgreSQL (compose-сервис postgres).
# Сгенерируй пароль: openssl rand -hex 16
POSTGRES_USER=marketpclce
POSTGRES_PASSWORD=
POSTGRES_DB=marketpclce
# DATABASE_URL должен использовать тот же POSTGRES_PASSWORD. host = postgres.
DATABASE_URL=postgres://marketpclce:CHANGE_ME@postgres:5432/marketpclce?sslmode=disable
DATABASE_MAX_CONNS=10

# ── OpenSearch (compose-сервис opensearch). security plugin отключён,
# но образ требует admin-password ≥ 10 символов с спец-символами.
# Сгенерируй: openssl rand -base64 24
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_INDEX_SPECIALISTS=specialists
OPENSEARCH_PASSWORD=

# ── Redis (compose-сервис redis).
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── S3 — Yandex Object Storage.
# Static access key из service account, см. console.cloud.yandex.ru.
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_USE_SSL=true
# Пустое = path-style ${endpoint}/${bucket}. Для CNAME укажи https://media.example.com
S3_PUBLIC_URL=

# ── LLM. Без LLM_API_KEY эндпоинты /search/summarize и /clarify не маунтятся.
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6
LLM_BASE_URL=https://api.anthropic.com
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=60s
LLM_EFFORT=medium

# ── JWT. ОБЯЗАТЕЛЬНО сгенерировать: openssl rand -hex 32
JWT_SECRET=
JWT_ACCESS_TTL=30m
JWT_REFRESH_TTL=720h

# ── Rate-limit (Redis). Дефолты подходят для беты, можно поджимать.
SUMMARIZE_CACHE_TTL=10m
RATE_SUMMARIZE_PER_MIN=5
RATE_SUMMARIZE_PER_HOUR=30
RATE_READ_PER_MIN=60
RATE_READ_PER_HOUR=600
RATE_LEADS_PER_MIN=5
RATE_LEADS_PER_HOUR=20
RATE_AUTH_PER_MIN=10
RATE_AUTH_PER_HOUR=60

# ── Email verification (Unisender Go). В проде ОБЯЗАТЕЛЬНО:
#   - EMAIL_VERIFICATION_DISABLED=false (или не задавать — default false)
#   - UNISENDER_API_KEY заполнен (личный кабинет Unisender Go → API Keys)
#   - UNISENDER_FROM_EMAIL на верифицированном в Unisender домене (с SPF/DKIM)
#   - APP_BASE_URL = публичный URL фронта (используется в verify-ссылке)
EMAIL_VERIFICATION_DISABLED=false
UNISENDER_API_KEY=
UNISENDER_API_BASE_URL=https://go1.unisender.ru/ru/transactional/api/v1
UNISENDER_FROM_EMAIL=noreply@example.com
UNISENDER_FROM_NAME=marketpclce
APP_BASE_URL=https://marketpclce.ru
EMAIL_VERIFY_TOKEN_TTL=24h
RATE_EMAIL_RESEND_PER=60s

LOG_LEVEL=info

# ── Разрешённые origin'ы фронта (через запятую). Если фронт на том же
# домене через Caddy proxy — оставь пустым.
CORS_ORIGINS=

# ── Мониторинг через Grafana Cloud (free tier).
# Setup: grafana.com → Sign up free → My Account → Stacks → твой стек →
#   Prometheus → "Send Metrics" → возьми Remote Write Endpoint, Username,
#   и сгенерируй API key (CloudAccessPolicy с permissions metrics:write+logs:write).
# То же для Loki. Если оставить пустым — alloy запустится, но не сможет
# пушить (логи самого alloy покажут 401/connection refused).
GRAFANA_CLOUD_PROM_URL=https://prometheus-prod-XX.grafana.net/api/prom/push
GRAFANA_CLOUD_PROM_USER=
GRAFANA_CLOUD_PROM_KEY=
GRAFANA_CLOUD_LOKI_URL=https://logs-prod-XXX.grafana.net/loki/api/v1/push
GRAFANA_CLOUD_LOKI_USER=
GRAFANA_CLOUD_LOKI_KEY=
